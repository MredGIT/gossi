# ──────────────────────────────────────────
#  GOSSI — Appwrite Configuration
#  Copy this file to .env.local and fill in
#  your Appwrite project details.
# ──────────────────────────────────────────

NEXT_PUBLIC_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_APPWRITE_DATABASE_ID=gossi_db

# Collection IDs (create these in Appwrite console)
NEXT_PUBLIC_COLLECTION_POSTS=post
NEXT_PUBLIC_COLLECTION_COMMENTS=comments
NEXT_PUBLIC_COLLECTION_REPORTS=reports
NEXT_PUBLIC_COLLECTION_ADS=ads
NEXT_PUBLIC_COLLECTION_BANNED_WORDS=banned_words
NEXT_PUBLIC_ADS_BUCKET_ID=ads_media

# Admin password – CHANGE THIS before going live!
NEXT_PUBLIC_ADMIN_PASSWORD=gossi2026

# App URL (used for share links)
NEXT_PUBLIC_APP_URL=https://anu.gossi.co.ke
